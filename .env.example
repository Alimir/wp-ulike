# Copy this file to .env and fill in your values.
# .env is gitignored and never included in plugin builds.

# Production deploy (npm run product)
DEPLOY_PROD_HOST=your-user@your-host.example
DEPLOY_PROD_PORT=22
DEPLOY_PROD_DEST=/home/your-user/www/wp-content/plugins/wp-ulike/

# WordPress.org SVN (npm run release)
WP_SVN_USER=your-wordpress-org-username
WP_SVN_PASSWORD=your-wordpress-org-application-password
WP_SVN_URL=https://plugins.svn.wordpress.org/wp-ulike

# Optional: preview release without publishing (WP_RELEASE_DRY_RUN=1 npm run release)
# WP_RELEASE_DRY_RUN=1
